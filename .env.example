# Copia questo file in .env e compila i valori

# Token del tuo bot (da https://discord.com/developers/applications)
DISCORD_TOKEN=il_tuo_token_qui

# ID del server Discord (opzionale – usa solo in sviluppo per sincronizzare i comandi subito)
# Lascia vuoto per sincronizzarli globalmente (può richiedere fino a 1 ora)
GUILD_ID=
